# Copy this file to .env and fill in values. .env is gitignored.

# ── LLM provider: "ollama" (local, free, offline) or "groq" (cloud, fast) ──
LLM_PROVIDER=ollama

# Used when LLM_PROVIDER=ollama
OLLAMA_MODEL=gemma3:1b
OLLAMA_BASE_URL=http://localhost:11434

# Used when LLM_PROVIDER=groq — get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

LLM_TEMPERATURE=0.1

# ── Embeddings & retrieval tuning (optional, sane defaults already set) ───
EMBEDDING_MODEL=thenlper/gte-small
CHUNK_SIZE=500
CHUNK_OVERLAP=75
RETRIEVAL_K=5

# ── Branding (optional) ────────────────────────────────────────────────
APP_TITLE=CourseMate
APP_ICON=🎓
ASSISTANT_NAME=CourseMate
